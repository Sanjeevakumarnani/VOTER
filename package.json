{
  "name": "votewise-ai",
  "version": "1.0.0",
  "description": "AI-powered Election Process Education Assistant for AMD Slingshot Campus Days",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "election",
    "education",
    "ai",
    "gemini",
    "google"
  ],
  "author": "VoteWise AI",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.50.1",
    "axios": "^1.15.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "public/js/modules/**/*.js"
    ],
    "transform": {},
    "transformIgnorePatterns": [
      "node_modules/(?!(@google/genai)/)"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
