# =============================================================================
# VoteWise AI — Environment Configuration Template
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual API key values.
# NEVER commit the .env file to version control — it contains sensitive keys!
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Get API keys from Google Cloud Console (see links below)
# 3. Replace placeholder values with your actual keys
# 4. For Cloud Run deployment, set these as environment variables in the console
# =============================================================================

# -----------------------------------------------------------------------------
# Google AI Services (REQUIRED: Gemini API)
# -----------------------------------------------------------------------------
# Get your Gemini API key from: https://aistudio.google.com/app/apikey
# This is REQUIRED for the AI features to work (explain, timeline, quiz, etc.)
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Google Maps API (OPTIONAL but recommended)
# -----------------------------------------------------------------------------
# Get your Google Maps API key from: https://console.cloud.google.com/google/maps-apis
# Enable these APIs in Google Cloud Console:
#   - Geocoding API (convert address to coordinates)
#   - Places API (search for polling stations)
#   - Maps JavaScript API (display maps)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# -----------------------------------------------------------------------------
# Google Cloud Translation API (OPTIONAL)
# -----------------------------------------------------------------------------
# Get your API key from: https://console.cloud.google.com/apis/library/translate.googleapis.com
# Or use the same key as Maps if using the same Google Cloud project
# Supports 13 Indian languages: Hindi, Bengali, Telugu, Marathi, Tamil, Urdu,
# Gujarati, Kannada, Malayalam, Punjabi, Assamese, Odia
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Server port (Cloud Run automatically sets this to 8080)
# Default: 8080 (required for Cloud Run compatibility)
PORT=8080

# Environment mode
# Options: development | production
# Default: development
NODE_ENV=development
